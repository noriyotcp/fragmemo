{
  "name": "fragmemo",
  "productName": "fragmemo",
  "private": true,
  "version": "2.0.0",
  "description": "Snippet tool",
  "author": {
    "name": "noriyotcp",
    "email": "noriyo.akita@gmail.com"
  },
  "license": "MIT",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "rebuild": "node scripts/rebuild.cjs",
    "postinstall": "npx electron-rebuild",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "app:build": "electron-vite build && electron-builder",
    "app:build:mac:x64": "electron-vite build && electron-builder --mac --x64",
    "app:build:mac:arm64": "electron-vite build && electron-builder --mac --arm64"
  },
  "build": {
    "appId": "com.electron.fragmemo",
    "productName": "fragmemo",
    "copyright": "Copyright (c) noriyotcp",
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "icons/icon.png",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "drizzle", "to": "drizzle" },
      { "from": "out/native", "to": "native" }
    ],
    "directories": {
      "output": "release"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "better-sqlite3": "^12.4.5",
    "drizzle-orm": "^0.44.7",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.22",
    "drizzle-kit": "^0.31.7",
    "electron": "^39.8.5",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  }
}
